<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AmbientSleeper.ViewModels"
             x:Class="AmbientSleeper.Views.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="AmbientSleeper">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="Ambient Sounds" FontAttributes="Bold" FontSize="20" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="Start Mix"
                        Command="{Binding Playback.StartMixCommand}" />
                <Button Text="Stop Mix"
                        Command="{Binding Playback.StopMixCommand}" />
                <Label Text="{Binding Playback.IsMixPlaying, StringFormat='Playing: {0}'}" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#cccccc" />

            <Label Text="Timer" FontSize="24" />

            <HorizontalStackLayout Spacing="12">
                <Button Text="+1 min" Command="{Binding Timer.AddMinuteCommand}" />
                <Button Text="-1 min" Command="{Binding Timer.SubtractMinuteCommand}" />
                <Label Text="{Binding Timer.Duration, StringFormat='Duration: {0:mm\\:ss}'}" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="12">
                <Button Text="Start Timer" Command="{Binding Timer.StartTimerCommand}" />
                <Button Text="Cancel" Command="{Binding Timer.CancelTimerCommand}" />
                <Label Text="{Binding Timer.Remaining, StringFormat='Remaining: {0:mm\\:ss}'}" VerticalOptions="Center" />
                <Label Text="{Binding Timer.IsRunning, StringFormat='Running: {0}'}" VerticalOptions="Center" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
