<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
      xmlns:resx="clr-namespace:AmbientSleeper.Resources.Strings"
     xmlns:vm="clr-namespace:AmbientSleeper.ViewModels"
    xmlns:models="clr-namespace:AmbientSleeper.Models"
         xmlns:svc="clr-namespace:AmbientSleeper.Services"
        x:Class="AmbientSleeper.Views.LibraryPage"
    x:DataType="vm:LibraryViewModel"
       x:Name="Root"
             Title="{x:Static resx:AppResources.Library_Title}">

    <ContentPage.Resources>
        <ResourceDictionary>
   <Color x:Key="TabActiveBg">#BF000000</Color>
            <Color x:Key="TabInactiveBg">#80FFFFFF</Color>
     <Color x:Key="TabActiveText">#FFFFFFFF</Color>
     <Color x:Key="TabInactiveText">#222222</Color>
      <Color x:Key="TabActiveBorder">#FFFFFFFF</Color>
 <Color x:Key="TabInactiveBorder">#CCFFFFFF</Color>

            <Style x:Key="TabButtonStyle" TargetType="Button">
        <Setter Property="HeightRequest" Value="40" />
  <Setter Property="FontSize" Value="16" />
           <Setter Property="FontAttributes" Value="Bold" />
       <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="{OnIdiom Phone='16,8', Tablet='20,10'}" />
      <Setter Property="Margin" Value="8,10" />
        <Setter Property="BorderWidth" Value="2" />
<Setter Property="BackgroundColor" Value="{StaticResource TabInactiveBg}" />
       <Setter Property="TextColor" Value="{StaticResource TabInactiveText}" />
 <Setter Property="BorderColor" Value="{StaticResource TabInactiveBorder}" />
 <Setter Property="Shadow">
      <Setter.Value>
  <Shadow Brush="#40000000" Opacity="0.6" Radius="6" />
   </Setter.Value>
    </Setter>
  </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <AbsoluteLayout>
        <Grid AbsoluteLayout.LayoutBounds="0,0,1,1"
      AbsoluteLayout.LayoutFlags="All"
RowDefinitions="Auto,*"
   Padding="{OnIdiom Phone=0, Tablet=10}">

  <!-- Tab header: 0=Bundles, 1=Your Audio, 2=Mix Playlist -->
    <Grid Grid.Row="0" ColumnDefinitions="*,*,*" Padding="{OnIdiom Phone='10,6', Tablet='16,8'}">
             <Button Grid.Column="0"
            Style="{StaticResource TabButtonStyle}"
    Text="{x:Static resx:AppResources.AudioBundles}"
    Command="{Binding ChangeTabCommand}"
      CommandParameter="0">
         <Button.Triggers>
  <DataTrigger TargetType="Button"
      Binding="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}"
          Value="True">
      <Setter Property="BackgroundColor" Value="{StaticResource TabActiveBg}" />
     <Setter Property="TextColor" Value="{StaticResource TabActiveText}" />
  <Setter Property="BorderColor" Value="{StaticResource TabActiveBorder}" />
       </DataTrigger>
      </Button.Triggers>
       </Button>

           <Button Grid.Column="1"
   Style="{StaticResource TabButtonStyle}"
        Text="{x:Static resx:AppResources.Tab_YourAudio}"
  Command="{Binding ChangeTabCommand}"
     CommandParameter="1">
       <Button.Triggers>
       <DataTrigger TargetType="Button"
Binding="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"
      Value="True">
      <Setter Property="BackgroundColor" Value="{StaticResource TabActiveBg}" />
    <Setter Property="TextColor" Value="{StaticResource TabActiveText}" />
     <Setter Property="BorderColor" Value="{StaticResource TabActiveBorder}" />
       </DataTrigger>
        </Button.Triggers>
  </Button>

        <Button Grid.Column="2"
       Style="{StaticResource TabButtonStyle}"
    Text="{x:Static resx:AppResources.Tab_MixPlaylist}"
         Command="{Binding ChangeTabCommand}"
 CommandParameter="2"
   IsEnabled="{Binding IsMixPlaylistEnabled}">
  <Button.Triggers>
  <DataTrigger TargetType="Button"
            Binding="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}"
  Value="True">
     <Setter Property="BackgroundColor" Value="{StaticResource TabActiveBg}" />
         <Setter Property="TextColor" Value="{StaticResource TabActiveText}" />
     <Setter Property="BorderColor" Value="{StaticResource TabActiveBorder}" />
   </DataTrigger>
        </Button.Triggers>
        </Button>
         </Grid>

      <!-- Tab content (no outer ScrollView so inner CollectionViews can virtualize efficiently) -->
  <Grid Grid.Row="1">

        <!-- Bundles tab (includes Built-in bundle) -->
  <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}"
   Padding="{OnIdiom Phone=16, Tablet=24}" Spacing="{OnIdiom Phone=16, Tablet=20}">
       <Label Text="{x:Static resx:AppResources.AudioBundles}" FontSize="22" FontAttributes="Bold" />
           <CollectionView ItemsSource="{Binding Bundles}">
     <CollectionView.ItemsLayout>
      <GridItemsLayout Orientation="Vertical" Span="{OnIdiom Phone=1, Tablet=2, Desktop=3}" />
 </CollectionView.ItemsLayout>
          <CollectionView.ItemTemplate>
         <DataTemplate x:DataType="vm:BundleViewModel">
<VerticalStackLayout Spacing="8" Padding="{OnIdiom Phone=8, Tablet=12}" BackgroundColor="#F8F8F8">
    <HorizontalStackLayout Spacing="8">
  <Label Text="{Binding Bundle.Name}" FontAttributes="Bold" FontSize="{OnIdiom Phone=18, Tablet=20}" />
       <Image Source="lock.png" WidthRequest="20" HeightRequest="20" IsVisible="{Binding IsUnlocked, Converter={StaticResource InverseBoolConverter}}" />
   </HorizontalStackLayout>
   <Label Text="{Binding Bundle.Description}" FontSize="{OnIdiom Phone=13, Tablet=14}" TextColor="#888" />
  <CollectionView ItemsSource="{Binding Files}" ItemsLayout="HorizontalList">
<CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:BundleFileViewModel">
<StackLayout Orientation="Vertical" Padding="4" WidthRequest="{OnIdiom Phone=120, Tablet=160}">
<Label Text="{Binding File.Name}" />
   <Label Text="{Binding File.DurationSeconds, StringFormat='Duration: {0:F0}s'}" FontSize="11" TextColor="#AAA" />
   <Image Source="lock.png" WidthRequest="16" HeightRequest="16" IsVisible="{Binding IsUnlocked, Converter={StaticResource InverseBoolConverter}}" />

     <Border BackgroundColor="#43A047" StrokeThickness="0" SemanticProperties.Description="{x:Static resx:AppResources.A11y_AddToMix}" IsEnabled="{Binding IsUnlocked}">
             <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
           <Grid WidthRequest="{OnIdiom Phone=100, Tablet=120}" HeightRequest="{OnIdiom Phone=40, Tablet=44}" Padding="0">
   <Grid.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=BindingContext.AddToMixCommand}" CommandParameter="{Binding AsAudioItem}" />
       </Grid.GestureRecognizers>
     <Label Text="?" FontSize="{OnIdiom Phone=20, Tablet=22}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" />
            <Border HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="White" Stroke="#2E7D32" Padding="0" HeightRequest="16" WidthRequest="16" StrokeThickness="1">
  <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
       <Label Text="+" FontSize="10" TextColor="#2E7D32" HorizontalOptions="Center" VerticalOptions="Center" />
  </Border>
     </Grid>
  </Border>

           <Border BackgroundColor="#008080" StrokeThickness="0" SemanticProperties.Description="{x:Static resx:AppResources.A11y_AddToPlaylist}" IsEnabled="{Binding IsUnlocked}">
 <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
         <Grid WidthRequest="{OnIdiom Phone=100, Tablet=120}" HeightRequest="{OnIdiom Phone=40, Tablet=44}" Padding="0">
      <Grid.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=BindingContext.AddToPlaylistCommand}" CommandParameter="{Binding AsAudioItem}" />
      </Grid.GestureRecognizers>
               <Label Text="?" FontSize="{OnIdiom Phone=20, Tablet=22}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" />
<Border HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="White" Stroke="#006666" Padding="0" HeightRequest="16" WidthRequest="16" StrokeThickness="1">
             <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
   <Label Text="+" FontSize="10" TextColor="#006666" HorizontalOptions="Center" VerticalOptions="Center" />
     </Border>
        </Grid>
   </Border>
 </StackLayout>
    </DataTemplate>
         </CollectionView.ItemTemplate>
    </CollectionView>
 </VerticalStackLayout>
</DataTemplate>
  </CollectionView.ItemTemplate>
      </CollectionView>
       </VerticalStackLayout>

       <!-- Your audio tab -->
      <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"
        Padding="{OnIdiom Phone=16, Tablet=24}" Spacing="{OnIdiom Phone=16, Tablet=20}">
       <Button Text="{x:Static resx:AppResources.ImportFromDevice}" Command="{Binding ImportDeviceAudioCommand}" />
        <CollectionView ItemsSource="{Binding DeviceAudio}">
     <CollectionView.ItemsLayout>
     <GridItemsLayout Orientation="Vertical" Span="{OnIdiom Phone=1, Tablet=2, Desktop=3}" />
  </CollectionView.ItemsLayout>
     <CollectionView.ItemTemplate>
  <DataTemplate x:DataType="models:AudioItem">
            <Grid Padding="{OnIdiom Phone=8, Tablet=12}" ColumnDefinitions="*,120,120" ColumnSpacing="8" VerticalOptions="Center">
          <Label Grid.Column="0" Text="{Binding Title}" FontSize="{OnIdiom Phone=Default, Tablet=18}" />

 <Border Grid.Column="1" BackgroundColor="#43A047" StrokeThickness="0" SemanticProperties.Description="{x:Static resx:AppResources.A11y_AddToMix}">
          <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
   <Grid WidthRequest="{OnIdiom Phone=120, Tablet=140}" HeightRequest="{OnIdiom Phone=44, Tablet=48}" Padding="0">
   <Grid.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding Source={x:Reference Root}, Path=BindingContext.AddToMixCommand}" CommandParameter="{Binding .}" />
      </Grid.GestureRecognizers>
             <Label Text="?" FontSize="{OnIdiom Phone=24, Tablet=28}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" />
         <Border HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="White" Stroke="#2E7D32" Padding="0" HeightRequest="18" WidthRequest="18" StrokeThickness="1">
   <Border.StrokeShape><RoundRectangle CornerRadius="9" /></Border.StrokeShape>
 <Label Text="+" FontSize="12" TextColor="#2E7D32" HorizontalOptions="Center" VerticalOptions="Center" />
          </Border>
     </Grid>
</Border>

     <Border Grid.Column="2" BackgroundColor="#008080" StrokeThickness="0" SemanticProperties.Description="{x:Static resx:AppResources.A11y_AddToPlaylist}">
          <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
    <Grid WidthRequest="{OnIdiom Phone=120, Tablet=140}" HeightRequest="{OnIdiom Phone=44, Tablet=48}" Padding="0">
<Grid.GestureRecognizers>
     <TapGestureRecognizer CommandParameter="{Binding .}"
   Command="{Binding Source={x:Reference Root}, Path=BindingContext.AddToPlaylistCommand}" />
      </Grid.GestureRecognizers>
   <Label Text="?" FontSize="{OnIdiom Phone=24, Tablet=28}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" />
    <Border HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="White" Stroke="#006666" Padding="0" HeightRequest="18" WidthRequest="18" StrokeThickness="1">
 <Border.StrokeShape><RoundRectangle CornerRadius="9" /></Border.StrokeShape>
        <Label Text="+" FontSize="12" TextColor="#006666" HorizontalOptions="Center" VerticalOptions="Center" />
           </Border>
            </Grid>
  </Border>
   </Grid>
        </DataTemplate>
    </CollectionView.ItemTemplate>
      </CollectionView>
        </VerticalStackLayout>

     <!-- Mix Playlist Library tab content -->
   <VerticalStackLayout IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}"
        Padding="{OnIdiom Phone=16, Tablet=24}" Spacing="{OnIdiom Phone=16, Tablet=20}" IsEnabled="{Binding IsMixPlaylistEnabled}">
<VerticalStackLayout.Triggers>
  <DataTrigger TargetType="VerticalStackLayout"
Binding="{Binding IsMixPlaylistEnabled}"
   Value="False">
          <Setter Property="Opacity" Value="0.5" />
    </DataTrigger>
      </VerticalStackLayout.Triggers>
  <Label Text="{x:Static resx:AppResources.MixPlaylist_Save}" FontAttributes="Bold" />
       <HorizontalStackLayout Spacing="8">
        <Entry x:Name="NewMixPlaylistNameEntry" Placeholder="{x:Static resx:AppResources.MixPlaylist_NamePlaceholder}" WidthRequest="{OnIdiom Phone=220, Tablet=320}" />
  <Button Text="??" Clicked="OnSaveMixPlaylistFromLibrary" />
     </HorizontalStackLayout>
   <Label Text="{x:Static resx:AppResources.MixPlaylist_Saved}" FontAttributes="Bold" Margin="0,16,0,0" />
        <CollectionView ItemsSource="{Binding MixPlaylists}" SelectionMode="None">
   <CollectionView.ItemsLayout>
           <GridItemsLayout Orientation="Vertical" Span="{OnIdiom Phone=1, Tablet=2, Desktop=3}" />
            </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
 <DataTemplate x:DataType="models:SavedMixPlaylist">
   <HorizontalStackLayout Spacing="8" Padding="8">
       <Label Text="{Binding Name}" VerticalOptions="Center" />
       <Button Text="??"
            Command="{Binding Source={x:Reference Root}, Path=BindingContext.DeleteMixPlaylistCommand}"
        CommandParameter="{Binding Name}" />
     </HorizontalStackLayout>
     </DataTemplate>
   </CollectionView.ItemTemplate>
   </CollectionView>
    </VerticalStackLayout>

      </Grid>
        </Grid>

<Border x:Name="ConfirmationPopup" AbsoluteLayout.LayoutBounds="0.5,0.1,-1,-1" AbsoluteLayout.LayoutFlags="PositionProportional" BackgroundColor="#CCFFFFFF" Stroke="#4CAF50" Padding="12" IsVisible="False">
   <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
            <Border.Shadow><Shadow Brush="#40000000" Opacity="0.4" Radius="6" /></Border.Shadow>
            <HorizontalStackLayout Spacing="8">
        <Image Source="check.png" WidthRequest="24" HeightRequest="24" />
         <Label Text="{x:Static resx:AppResources.Confirmation_SoundAdded}" TextColor="#4CAF50" FontAttributes="Bold" />
  </HorizontalStackLayout>
        </Border>

    </AbsoluteLayout>
</ContentPage>
