<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AmbientSleeper.ViewModels"
             xmlns:models="clr-namespace:AmbientSleeper.Models"
             x:Class="AmbientSleeper.Views.SoundsPage"
             x:DataType="viewmodels:SoundsViewModel">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <Label Text="Ambient sounds" FontAttributes="Bold" FontSize="20" />

                <CollectionView ItemsSource="{Binding Sounds}" SelectionMode="Single"
                                SelectedItem="{Binding SelectedSound, Mode=TwoWay}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SoundItem">
                            <Grid Padding="8" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding DisplayName}" FontSize="16" />
                                <Label Grid.Column="1" Text="▶" FontSize="16" TextColor="Gray" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Label Text="{Binding NowPlayingText}" />
                    <StackLayout Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Label Text="Loop" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding LoopEnabled}" />
                    </StackLayout>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Button Text="{Binding PlayPauseText}" Command="{Binding PlayPauseCommand}" />
                    <Button Grid.Column="1" Text="Stop" Command="{Binding StopCommand}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>