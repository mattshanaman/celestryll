<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:AmbientSleeper.Resources.Strings"
             xmlns:views="clr-namespace:AmbientSleeper.Views"
             x:Class="AmbientSleeper.Views.SettingsPage"
             x:DataType="views:SettingsPage"
             Title="{x:Static resx:AppResources.Settings_Title}">

	<ScrollView>
		<VerticalStackLayout Padding="{OnIdiom Phone=16, Tablet=24}" Spacing="{OnIdiom Phone=16, Tablet=20}">
			<Label Text="{x:Static resx:AppResources.Settings_ChoosePlan}" FontSize="{OnIdiom Phone=22, Tablet=24}" FontAttributes="Bold" />
			<Label Text="{x:Static resx:AppResources.Settings_Description}"
			       FontSize="14" TextColor="Gray" Margin="0,0,0,12" />

			<!-- Free Tier -->
			<Border Stroke="#80FFFFFF" StrokeThickness="2" Padding="16" BackgroundColor="#10FFFFFF">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12" />
				</Border.StrokeShape>
				<Border.Shadow>
					<Shadow Brush="#40000000" Opacity="0.3" Radius="8" />
				</Border.Shadow>
				<VerticalStackLayout Spacing="12">
					<HorizontalStackLayout Spacing="12">
						<RadioButton x:Name="FreeRadio" 
						             Content="{x:Static resx:AppResources.Settings_Free_Title}" 
						             GroupName="Plans" 
						             CheckedChanged="OnFreeChecked"
						             FontSize="18"
						             FontAttributes="Bold" />
						<Label Text="{x:Static resx:AppResources.Settings_Free_Badge}" 
						       VerticalOptions="Center"
						       TextColor="#4CAF50"
						       FontAttributes="Bold" />
					</HorizontalStackLayout>
					<Label Text="{x:Static resx:AppResources.Settings_Free_Description}" FontSize="12" TextColor="Gray" />
					<StackLayout Spacing="4" Margin="24,0,0,0">
						<Label Text="{x:Static resx:AppResources.Settings_Free_Feature1}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Free_Feature2}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Free_Feature3}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Free_Limit}" FontSize="13" TextColor="Gray" />
					</StackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Recurring Subscriptions -->
			<Label Text="{x:Static resx:AppResources.Settings_RecurringSubscriptions}" FontAttributes="Bold" FontSize="{OnIdiom Phone=18, Tablet=20}" Margin="0,16,0,0" />
			
			<!-- Standard Subscription -->
			<Border Stroke="#80FFFFFF" StrokeThickness="2" Padding="16" BackgroundColor="#10FFFFFF">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12" />
				</Border.StrokeShape>
				<Border.Shadow>
					<Shadow Brush="#40000000" Opacity="0.3" Radius="8" />
				</Border.Shadow>
				<VerticalStackLayout Spacing="12">
					<HorizontalStackLayout Spacing="12">
						<RadioButton x:Name="StandardSubRadio" 
						             Content="{x:Static resx:AppResources.Settings_Standard_Title}" 
						             GroupName="Plans" 
						             CheckedChanged="OnStandardChecked"
						             FontSize="18"
						             FontAttributes="Bold" />
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Monthly}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#2196F3" />
						<Label Text="{x:Static resx:AppResources.Settings_Or}" 
						       VerticalOptions="Center"
						       TextColor="#2196F3" />
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Yearly}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#2196F3" />
					</HorizontalStackLayout>
					<StackLayout Spacing="4" Margin="24,0,0,0">
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Feature1}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Feature2}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Feature3}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Feature4}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Feature5}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Standard_Feature6}" FontSize="13" />
					</StackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Premium Subscription -->
			<Border Stroke="#FFC107" StrokeThickness="3" Padding="16" BackgroundColor="#20FFC107">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12" />
				</Border.StrokeShape>
				<Border.Shadow>
					<Shadow Brush="#40FFC107" Opacity="0.5" Radius="12" />
				</Border.Shadow>
				<VerticalStackLayout Spacing="12">
					<HorizontalStackLayout Spacing="12">
						<RadioButton x:Name="PremiumSubRadio" 
						             Content="{x:Static resx:AppResources.Settings_Premium_Title}" 
						             GroupName="Plans" 
						             CheckedChanged="OnPremiumChecked"
						             FontSize="18"
						             FontAttributes="Bold" />
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Monthly}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#FFC107" />
						<Label Text="{x:Static resx:AppResources.Settings_Or}" 
						       VerticalOptions="Center"
						       TextColor="#FFC107" />
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Yearly}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#FFC107" />
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Badge}" 
						       BackgroundColor="#FFC107"
						       TextColor="Black"
						       FontAttributes="Bold"
						       FontSize="10"
						       Padding="6,2"
						       VerticalOptions="Center">
							<Label.GestureRecognizers>
								<TapGestureRecognizer />
							</Label.GestureRecognizers>
						</Label>
					</HorizontalStackLayout>
					<StackLayout Spacing="4" Margin="24,0,0,0">
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Feature1}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Feature2}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Feature3}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Feature4}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_Premium_Feature5}" FontSize="13" />
					</StackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Pro+ Subscription -->
			<Border Stroke="#9C27B0" StrokeThickness="3" Padding="16" BackgroundColor="#209C27B0">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12" />
				</Border.StrokeShape>
				<Border.Shadow>
					<Shadow Brush="#409C27B0" Opacity="0.5" Radius="12" />
				</Border.Shadow>
				<VerticalStackLayout Spacing="12">
					<HorizontalStackLayout Spacing="12">
						<RadioButton x:Name="ProPlusSubRadio" 
						             Content="{x:Static resx:AppResources.Settings_ProPlus_Title}" 
						             GroupName="Plans" 
						             CheckedChanged="OnProPlusChecked"
						             FontSize="18"
						             FontAttributes="Bold" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Monthly}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#9C27B0" />
						<Label Text="{x:Static resx:AppResources.Settings_Or}" 
						       VerticalOptions="Center"
						       TextColor="#9C27B0" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Yearly}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#9C27B0" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Badge}" 
						       BackgroundColor="#9C27B0"
						       TextColor="White"
						       FontAttributes="Bold"
						       FontSize="10"
						       Padding="6,2"
						       VerticalOptions="Center" />
					</HorizontalStackLayout>
					<StackLayout Spacing="4" Margin="24,0,0,0">
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Feature1}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Feature2}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Feature3}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Feature4}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Feature5}" FontSize="13" />
						<Label Text="{x:Static resx:AppResources.Settings_ProPlus_Feature6}" FontSize="13" />
					</StackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Lifetime Purchases -->
			<Label Text="{x:Static resx:AppResources.Settings_LifetimeTitle}" FontAttributes="Bold" FontSize="{OnIdiom Phone=18, Tablet=20}" Margin="0,24,0,0" />
			<Label Text="{x:Static resx:AppResources.Settings_LifetimeDescription}"
			       FontSize="12" TextColor="Gray" Margin="0,0,0,8" />
			
			<!-- Standard Lifetime -->
			<Border Stroke="#80FFFFFF" StrokeThickness="2" Padding="16" BackgroundColor="#10FFFFFF">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="12">
					<HorizontalStackLayout Spacing="12">
						<RadioButton x:Name="StandardLifetimeRadio" 
						             Content="{x:Static resx:AppResources.Settings_StandardLifetime_Title}" 
						             GroupName="Plans" 
						             CheckedChanged="OnStandardLifetimeChecked"
						             FontSize="18"
						             FontAttributes="Bold" />
						<Label Text="{x:Static resx:AppResources.Settings_StandardLifetime_Price}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#4CAF50" />
					</HorizontalStackLayout>
					<Label Text="{x:Static resx:AppResources.Settings_StandardLifetime_Features}" FontSize="12" TextColor="Gray" />
					<Label Text="{x:Static resx:AppResources.Settings_StandardLifetime_Savings}" FontSize="12" TextColor="#4CAF50" FontAttributes="Bold" Margin="24,0,0,0" />
				</VerticalStackLayout>
			</Border>

			<!-- Premium Lifetime -->
			<Border Stroke="#FFC107" StrokeThickness="2" Padding="16" BackgroundColor="#10FFC107">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="12">
					<HorizontalStackLayout Spacing="12">
						<RadioButton x:Name="PremiumLifetimeRadio" 
						             Content="{x:Static resx:AppResources.Settings_PremiumLifetime_Title}" 
						             GroupName="Plans" 
						             CheckedChanged="OnPremiumLifetimeChecked"
						             FontSize="18"
						             FontAttributes="Bold" />
						<Label Text="{x:Static resx:AppResources.Settings_PremiumLifetime_Price}" 
						       VerticalOptions="Center"
						       FontAttributes="Bold"
						       TextColor="#FFC107" />
						<Label Text="{x:Static resx:AppResources.Settings_PremiumLifetime_Badge}" 
						       BackgroundColor="#FFC107"
						       TextColor="Black"
						       FontAttributes="Bold"
						       FontSize="10"
						       Padding="6,2"
						       VerticalOptions="Center" />
					</HorizontalStackLayout>
					<Label Text="{x:Static resx:AppResources.Settings_PremiumLifetime_Features}" FontSize="12" TextColor="Gray" />
					<Label Text="{x:Static resx:AppResources.Settings_PremiumLifetime_Savings}" FontSize="12" TextColor="#4CAF50" FontAttributes="Bold" Margin="24,0,0,0" />
				</VerticalStackLayout>
			</Border>

			<!-- Current Tier Display -->
			<BoxView HeightRequest="2" BackgroundColor="#80FFFFFF" Margin="0,24,0,12" />
			<Border Stroke="#2196F3" StrokeThickness="2" Padding="16" BackgroundColor="#202196F3">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="8">
					<Label Text="{x:Static resx:AppResources.Settings_CurrentStatus}" FontAttributes="Bold" FontSize="16" />
					<Label x:Name="CurrentTierLabel" FontSize="18" FontAttributes="Bold" TextColor="#4CAF50" />
				</VerticalStackLayout>
			</Border>
			
			<!-- Diagnostics Section -->
			<BoxView HeightRequest="1" BackgroundColor="#80FFFFFF" Margin="0,24,0,12" />
			
			<Label Text="{x:Static resx:AppResources.Settings_Diagnostics_Title}" FontSize="{OnIdiom Phone=18, Tablet=20}" FontAttributes="Bold" />
			<Label Text="{x:Static resx:AppResources.Settings_Diagnostics_Description}"
			       FontSize="12" TextColor="Gray" />
			
			<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
				<Button Grid.Column="0"
				        Text="{x:Static resx:AppResources.Settings_CheckHealth}" 
				        Clicked="OnCheckHealthClicked"
				        FontSize="14"
				        Padding="12" />
				<Button Grid.Column="1"
				        Text="{x:Static resx:AppResources.Settings_ErrorReport}" 
				        Clicked="OnViewErrorReportClicked"
				        FontSize="14"
				        Padding="12" />
			</Grid>
			
			<Label x:Name="HealthStatusLabel" FontSize="13" TextColor="Gray" Margin="0,8,0,0" />
			
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>