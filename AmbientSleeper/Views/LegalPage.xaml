<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:res="clr-namespace:AmbientSleeper.Resources.Strings"
        xmlns:views="clr-namespace:AmbientSleeper.Views"
             x:Class="AmbientSleeper.Views.LegalPage"
             x:DataType="views:LegalPage"
          Title="{x:Static res:AppResources.Legal_Title}">
    <Grid>
<WebView x:Name="LegalWebView" />
        
  <ActivityIndicator x:Name="LoadingIndicator"
  IsRunning="True"
IsVisible="True"
     Color="{DynamicResource Color.Primary}"
       VerticalOptions="Center"
     HorizontalOptions="Center" />
    </Grid>
</ContentPage>
