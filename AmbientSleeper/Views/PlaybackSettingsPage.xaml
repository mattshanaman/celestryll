<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:AmbientSleeper.Resources.Strings"
             xmlns:vm="clr-namespace:AmbientSleeper.ViewModels"
             x:Class="AmbientSleeper.Views.PlaybackSettingsPage"
             x:DataType="vm:PlaybackSettingsViewModel"
             Title="{x:Static resx:AppResources.PlaybackSettings_Title}">
    <ScrollView>
        <VerticalStackLayout Padding="{OnIdiom Phone=16, Tablet=24}" Spacing="{OnIdiom Phone=20, Tablet=24}">
            
            <Label Text="{x:Static resx:AppResources.PlaybackSettings_AudioSettings}" FontAttributes="Bold" FontSize="{OnIdiom Phone=22, Tablet=24}" />
            <Label Text="{x:Static resx:AppResources.PlaybackSettings_Description}"
                   FontSize="14" TextColor="Gray" Margin="0,0,0,12" />
            
            <!-- Fade-out Section -->
            <Border Stroke="#80FFFFFF" StrokeThickness="2" Padding="16" BackgroundColor="#10FFFFFF">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_FadeOutTitle}" FontAttributes="Bold" FontSize="{OnIdiom Phone=18, Tablet=20}" />
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_FadeOutDescription}"
                           FontSize="13" TextColor="Gray" />
                    
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,8,0,0">
                        <Label Grid.Column="0" 
                               Text="{x:Static resx:AppResources.PlaybackSettings_MinFade}" 
                               FontSize="13"
                               TextColor="Gray"
                               VerticalOptions="Center" />
                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding MaxFadeSeconds}"
                                Value="{Binding FadeOutSeconds, Mode=TwoWay}"
                                MinimumTrackColor="#4CAF50"
                                MaximumTrackColor="#80FFFFFF" />
                        <Label Grid.Column="2" 
                               Text="{Binding MaxFadeSeconds, StringFormat='{0}s'}" 
                               FontSize="13"
                               TextColor="Gray"
                               VerticalOptions="Center" />
                    </Grid>
                    
                    <Border Stroke="#4CAF50" StrokeThickness="2" Padding="12" BackgroundColor="#204CAF50">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{x:Static resx:AppResources.PlaybackSettings_Current}" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding FadeOutSeconds, StringFormat={x:Static resx:AppResources.PlaybackSettings_SecondsFormat}}" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    
                    <Label Text="{Binding MaxFadeSeconds, StringFormat={x:Static resx:AppResources.PlaybackSettings_TierAllowsFormat}}" 
                           FontSize="12" 
                           TextColor="Gray" 
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>
            
            <BoxView HeightRequest="1" BackgroundColor="#80FFFFFF" Margin="0,8" />
            
            <!-- Alarm Section -->
            <Border Stroke="#80FFFFFF" StrokeThickness="2" Padding="16" BackgroundColor="#10FFFFFF">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_AlarmIntegration}" FontAttributes="Bold" FontSize="{OnIdiom Phone=18, Tablet=20}" />
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_AlarmDescription}"
                           FontSize="13" TextColor="Gray" />
                    
                    <!-- Locked Message -->
                    <Border IsVisible="{Binding IsAlarmIntegrationEnabled, Converter={StaticResource InverseBoolConverter}}"
                            BackgroundColor="#40FF9800"
                            Stroke="#FF9800"
                            StrokeThickness="2"
                            Padding="12"
                            Margin="0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="6" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{x:Static resx:AppResources.PlaybackSettings_AlarmLocked_Title}" FontAttributes="Bold" FontSize="14" />
                            <Label Text="{x:Static resx:AppResources.PlaybackSettings_AlarmLocked_Message}" 
                                   FontSize="13" />
                            <Label Text="{x:Static resx:AppResources.PlaybackSettings_AlarmFreeNote}" 
                                   FontSize="12" 
                                   TextColor="Gray"
                                   FontAttributes="Italic" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="{x:Static resx:AppResources.PlaybackSettings_EnableAlarm}" VerticalOptions="Center" FontSize="15" />
                        <Switch IsToggled="{Binding AlarmEnabled}" 
                                OnColor="#4CAF50"
                                ThumbColor="White" />
                        <Label Text="{Binding AlarmEnabled, StringFormat='({0})'}"
                               VerticalOptions="Center"
                               FontSize="13"
                               TextColor="Gray">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding AlarmEnabled}" Value="True">
                                    <Setter Property="Text" Value="{x:Static resx:AppResources.PlaybackSettings_On}" />
                                    <Setter Property="TextColor" Value="#4CAF50" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding AlarmEnabled}" Value="False">
                                    <Setter Property="Text" Value="{x:Static resx:AppResources.PlaybackSettings_Off}" />
                                    <Setter Property="TextColor" Value="Gray" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </HorizontalStackLayout>
                    
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsAlarmIntegrationEnabled}">
                        <Button Text="{x:Static resx:AppResources.PlaybackSettings_ChooseAlarmSound}"
                                Command="{Binding PickAlarmCommand}"
                                IsEnabled="{Binding IsAlarmIntegrationEnabled}"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                Padding="14" />
                        
                        <Border Stroke="#2196F3" StrokeThickness="1" Padding="10" BackgroundColor="#102196F3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{x:Static resx:AppResources.PlaybackSettings_SelectedAlarm}" FontSize="12" TextColor="Gray" />
                                <Label Text="{Binding SelectedAlarm, TargetNullValue={x:Static resx:AppResources.PlaybackSettings_NoneSelected}}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
            
            <!-- Settings Tips -->
            <Border Stroke="#80FFFFFF" StrokeThickness="1" Padding="12" BackgroundColor="#10FFFFFF" Margin="0,16,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_TipsTitle}" FontAttributes="Bold" FontSize="14" />
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_Tip1}"
                           FontSize="12" TextColor="Gray" />
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_Tip2}"
                           FontSize="12" TextColor="Gray" />
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_Tip3}"
                           FontSize="12" TextColor="Gray" />
                    <Label Text="{x:Static resx:AppResources.PlaybackSettings_Tip4}"
                           FontSize="12" TextColor="Gray" />
                </VerticalStackLayout>
            </Border>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>