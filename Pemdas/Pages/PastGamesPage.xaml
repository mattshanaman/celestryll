<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Pemdas.ViewModels"
             x:Name="PastGamesRoot"
             x:Class="Pemdas.Pages.PastGamesPage"
             x:DataType="viewmodels:PastGamesViewModel"
             Title="{Binding Title}">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">

        <Label Grid.Row="0"
               Text="Premium archive access"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Frame Grid.Row="1"
               Padding="12"
               IsVisible="{Binding IsSubscribed, Converter={StaticResource InvertedBoolConverter}}"
               BackgroundColor="{StaticResource Gray100}">
            <Label Text="Subscribe to unlock past games and ad-free access to all daily levels."
                   HorizontalTextAlignment="Center" />
        </Frame>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding PastGames}"
                        SelectionMode="None"
                        IsVisible="{Binding IsSubscribed}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:PastGameItem">
                    <Frame Margin="0,4"
                           Padding="10"
                           BorderColor="{StaticResource Gray300}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="2">
                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding DateDisplay}"
                                   FontAttributes="Bold" />
                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding Subtitle}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray600}" />

                            <Button Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Text="Play"
                                    Command="{Binding Source={x:Reference PastGamesRoot}, Path=BindingContext.OpenPastGameCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    Padding="12,6" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}" />
    </Grid>

</ContentPage>
